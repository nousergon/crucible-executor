[Unit]
Description=Upstream artifact-freshness gate dry-run validation (config#1725)
After=ibgateway.service
Wants=ibgateway.service

[Service]
Type=oneshot
User=ec2-user
WorkingDirectory=/home/ec2-user/alpha-engine
ExecStart=/bin/bash /home/ec2-user/alpha-engine/infrastructure/ops/upstream-gate-dryrun-validation.sh
StandardOutput=journal
StandardError=journal
