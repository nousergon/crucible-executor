{
    "Version": "2012-10-17",
    "Statement": [
        {
            "Sid": "GroomSpotSsmCloudWatchLogs",
            "Effect": "Allow",
            "Action": [
                "logs:CreateLogGroup",
                "logs:CreateLogStream",
                "logs:PutLogEvents"
            ],
            "Resource": "arn:aws:logs:us-east-1:711398986525:log-group:/alpha-engine/groom-spot:*"
        }
    ]
}
