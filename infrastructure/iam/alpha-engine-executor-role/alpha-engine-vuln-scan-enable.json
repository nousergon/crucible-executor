{
    "Version": "2012-10-17",
    "Statement": [
        {
            "Sid": "ECREnhancedScanningRegistryConfig",
            "Effect": "Allow",
            "Action": [
                "ecr:GetRegistryScanningConfiguration",
                "ecr:PutRegistryScanningConfiguration"
            ],
            "Resource": "*"
        },
        {
            "Sid": "ECRDescribeEvaluatorRepo",
            "Effect": "Allow",
            "Action": "ecr:DescribeRepositories",
            "Resource": "arn:aws:ecr:us-east-1:711398986525:repository/alpha-engine-evaluator"
        },
        {
            "Sid": "SSMPatchBaselineScanOnlyAssociation",
            "Effect": "Allow",
            "Action": "ssm:CreateAssociation",
            "Resource": [
                "arn:aws:ssm:us-east-1::document/AWS-DefaultPatchBaseline",
                "arn:aws:ec2:us-east-1:711398986525:instance/i-018eb3307a21329bf",
                "arn:aws:ec2:us-east-1:711398986525:instance/i-09b539c844515d549"
            ]
        },
        {
            "Sid": "SSMPatchComplianceRead",
            "Effect": "Allow",
            "Action": [
                "ssm:DescribePatchBaselines",
                "ssm:ListComplianceItems"
            ],
            "Resource": "*"
        },
        {
            "Sid": "InspectorEnableForECREnhancedScanning",
            "Effect": "Allow",
            "Action": [
                "inspector2:Enable",
                "inspector2:BatchGetAccountStatus"
            ],
            "Resource": "*"
        }
    ]
}
