{
    "Version": "2012-10-17",
    "Statement": [
        {
            "Sid": "CypheringSignalParamRead",
            "Effect": "Allow",
            "Action": [
                "ssm:GetParameter",
                "ssm:GetParameters"
            ],
            "Resource": "arn:aws:ssm:us-east-1:711398986525:parameter/cyphering/signal/*"
        },
        {
            "Sid": "CypheringSignalParamDecrypt",
            "Effect": "Allow",
            "Action": "kms:Decrypt",
            "Resource": "*",
            "Condition": {
                "StringEquals": {
                    "kms:ViaService": "ssm.us-east-1.amazonaws.com"
                }
            }
        }
    ]
}
