{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "PassExecutorRoleToEc2ForSpotBacktest",
      "Effect": "Allow",
      "Action": "iam:PassRole",
      "Resource": "arn:aws:iam::711398986525:role/alpha-engine-executor-role",
      "Condition": {
        "StringEquals": {
          "iam:PassedToService": "ec2.amazonaws.com"
        }
      }
    }
  ]
}
