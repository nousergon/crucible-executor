{
    "Version": "2012-10-17",
    "Statement": [
        {
            "Sid": "ReadCodifiedRoles",
            "Effect": "Allow",
            "Action": [
                "iam:ListRolePolicies",
                "iam:GetRolePolicy",
                "iam:GetRole",
                "iam:ListAttachedRolePolicies"
            ],
            "Resource": [
                "arn:aws:iam::711398986525:role/alpha-engine-executor-role",
                "arn:aws:iam::711398986525:role/alpha-engine-dashboard-role",
                "arn:aws:iam::711398986525:role/alpha-engine-step-functions-role",
                "arn:aws:iam::711398986525:role/alpha-engine-eventbridge-sfn-role",
                "arn:aws:iam::711398986525:role/alpha-engine-predictor-role",
                "arn:aws:iam::711398986525:role/alpha-engine-data-role",
                "arn:aws:iam::711398986525:role/github-actions-iam-drift-check",
                "arn:aws:iam::711398986525:role/github-actions-lambda-deploy",
                "arn:aws:iam::711398986525:role/alpha-engine-changelog-cloudwatch-mirror-role",
                "arn:aws:iam::711398986525:role/alpha-engine-changelog-incident-mirror",
                "arn:aws:iam::711398986525:role/alpha-engine-ci-watch-dispatcher-role",
                "arn:aws:iam::711398986525:role/alpha-engine-crypto-balances-role",
                "arn:aws:iam::711398986525:role/alpha-engine-data-spot-dispatcher-role",
                "arn:aws:iam::711398986525:role/alpha-engine-eod-backstop-role",
                "arn:aws:iam::711398986525:role/alpha-engine-eod-success-friday-shell-trigger-role",
                "arn:aws:iam::711398986525:role/alpha-engine-freshness-monitor-role",
                "arn:aws:iam::711398986525:role/alpha-engine-friday-shell-run-report-role",
                "arn:aws:iam::711398986525:role/alpha-engine-groom-liveness-probe-role",
                "arn:aws:iam::711398986525:role/alpha-engine-pipeline-watchdog-role",
                "arn:aws:iam::711398986525:role/alpha-engine-saturday-integrity-sentinel-role",
                "arn:aws:iam::711398986525:role/alpha-engine-saturday-sf-watch-dispatcher-role",
                "arn:aws:iam::711398986525:role/alpha-engine-scheduled-groom-dispatcher-role",
                "arn:aws:iam::711398986525:role/alpha-engine-sf-telegram-notifier-role",
                "arn:aws:iam::711398986525:role/alpha-engine-sf-watch-liveness-probe-role",
                "arn:aws:iam::711398986525:role/alpha-engine-sf-watch-spot-dispatcher-role",
                "arn:aws:iam::711398986525:role/alpha-engine-spot-orphan-reaper-role",
                "arn:aws:iam::711398986525:role/alpha-engine-ssm-liveness-poller-role",
                "arn:aws:iam::711398986525:role/alpha-engine-usage-pace-alert-role",
                "arn:aws:iam::711398986525:role/alpha-engine-weekly-schedule-adjuster-role"
            ]
        },
        {
            "Sid": "ReadEventBridgeRulesForSfArnDriftCheck",
            "Effect": "Allow",
            "Action": [
                "events:DescribeRule",
                "events:ListRules"
            ],
            "Resource": "*"
        },
        {
            "Sid": "DescribeStateMachinesForSfArnDriftCheck",
            "Effect": "Allow",
            "Action": "states:DescribeStateMachine",
            "Resource": [
                "arn:aws:states:us-east-1:711398986525:stateMachine:ne-weekly-freshness-pipeline",
                "arn:aws:states:us-east-1:711398986525:stateMachine:ne-preopen-trading-pipeline",
                "arn:aws:states:us-east-1:711398986525:stateMachine:ne-postclose-trading-pipeline",
                "arn:aws:states:us-east-1:711398986525:stateMachine:alpha-engine-groom-dispatch",
                "arn:aws:states:us-east-1:711398986525:stateMachine:ne-weekly-advisory-pipeline",
                "arn:aws:states:us-east-1:711398986525:stateMachine:ne-modelzoo-sunday-pipeline"
            ]
        },
        {
            "Sid": "ListStateMachinesForSfArnDriftCheck",
            "Effect": "Allow",
            "Action": "states:ListStateMachines",
            "Resource": "*"
        },
        {
            "Sid": "GetFunctionForSfLambdaExistenceCheck",
            "Effect": "Allow",
            "Action": "lambda:GetFunction",
            "Resource": "*"
        }
    ]
}
