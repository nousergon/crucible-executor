# Alpha Engine — Executor Risk Parameters
# Copy this file to config/risk.yaml and customise all values below.
# config/risk.yaml is gitignored and should never be committed.
# These are intentionally conservative defaults — tune to your own portfolio.

# ── Short-sale prevention ────────────────────────────────────────────────────
allow_shorts: false              # true = allow sells that create short positions (use with caution)

# ── Position limits ──────────────────────────────────────────────────────────
max_position_pct: 0.05           # 5% NAV per position (hard cap)
max_sector_pct: 0.25             # 25% NAV per sector
max_equity_pct: 0.90             # 90% NAV in equities — always hold some cash

# Bear-regime overrides (applied when market_regime == "bear")
bear_max_position_pct: 0.025     # 2.5% in bear regime
bear_block_underweight: true     # no new entries in UW sectors in bear

# Circuit breaker
drawdown_circuit_breaker: 0.06   # halt new entries if portfolio drawdown exceeds this

# ── Entry gates ──────────────────────────────────────────────────────────────
min_score_to_enter: 30           # backstop only — predictor veto is primary gate

# Tighten min_score_to_enter when the predictor batch's mean prediction_confidence
# is broadly low (degenerate-predictor backstop, per 2026-05-07 audit Phase 1).
# Today's incident: 16 of 27 tickers clamped to p_up=0.458 (mean batch conf ~0.60),
# 5 saturated at conf=0.99 — the per-ticker signal looked fine but the batch
# distribution was degenerate. Default off; opt in only after shadow validation.
batch_confidence_tightening_enabled: false
batch_confidence_threshold: 0.65    # if mean batch confidence < this, tighten
batch_confidence_min_score_bump: 10 # bump min_score_to_enter by this when triggered
momentum_gate_enabled: false      # disabled — predictor mean-reversion conflicts with this
min_conviction_to_enter:         # only these conviction levels allow new entries
  - rising
  - stable

# Momentum confirmation gate — skip entries with weak momentum
momentum_gate_enabled: true
momentum_gate_threshold: -5.0   # min 20d momentum % (backtester-tunable: [-10.0, -5.0, -2.0])

# Cross-ticker correlation blocking — prevent correlated entries
correlation_block_enabled: true
correlation_block_threshold: 0.80  # max mean pairwise correlation (backtester-tunable: [0.70, 0.75, 0.80, 0.85])
correlation_lookback_days: 60

# ── Sizing adjustments ──────────────────────────────────────────────────────
min_price_target_upside: 0.08    # below this: apply upside_fail_adj
sector_adj:
  overweight: 1.05
  market_weight: 1.00
  underweight: 0.85
conviction_decline_adj: 0.70     # multiplier when conviction == "declining"
upside_fail_adj: 0.70            # multiplier when upside < min_price_target_upside
min_position_dollar: 500         # skip entries below this dollar size (safety param)
reduce_fraction: 0.50            # fraction of position to sell on REDUCE (backtester-tunable)

# ── ATR-based sizing ──────────────────────────────────────────────────────
atr_sizing_enabled: true
atr_sizing_target_risk: 0.02    # target risk per position (backtester-tunable: [0.01, 0.02, 0.03])

# ── Confidence-weighted sizing ─────────────────────────────────────────────
confidence_sizing_enabled: true
confidence_sizing_min: 0.70      # min confidence multiplier (backtester-tunable: [0.6, 0.7, 0.8])
confidence_sizing_range: 0.60    # range of confidence adjustment (backtester-tunable: [0.4, 0.6, 0.8])

# ── Signal staleness discount ──────────────────────────────────────────────
staleness_discount_enabled: true
signal_cadence_days: 7           # expected refresh interval (research runs weekly Sat) — decay only applies beyond this grace
staleness_decay_per_day: 0.03    # 3% decay per day past cadence (backtester-tunable: [0.02, 0.03, 0.05])
staleness_floor: 0.70            # minimum staleness multiplier

# ── Earnings sizing adjustment ──────────────────────────────────────────────
earnings_sizing_enabled: true
earnings_proximity_days: 5       # days before earnings to apply reduction (backtester-tunable: [3, 5, 7])
earnings_sizing_reduction: 0.50  # size reduction near earnings (backtester-tunable: [0.30, 0.50, 0.70])

# ── Feature-coverage sizing + admission (short-history handling) ────────────
# Paired controls for tickers whose long-window features (momentum_252d,
# dist_from_52w_high, return_252d) are NaN because they have < 252 bars of
# history. Supersedes the 2026-04-21 morning "quarantine at admission"
# framing: we trade new listings, just size them proportional to the
# information we have.
coverage_sizing_enabled: true    # derate position size by feature_coverage_fraction
coverage_derate_floor: 0.25      # never derate below 25% of normal size (backtester-tunable: [0.10, 0.25, 0.50])

coverage_admission_enabled: true        # hard-refuse buy_candidates below min_coverage_for_admission
min_coverage_for_admission: 0.30        # feature-coverage floor for NEW entries (backtester-tunable: [0.20, 0.30, 0.50])

# ── IBKR connection ─────────────────────────────────────────────────────────
ibkr_host: "127.0.0.1"
ibkr_port: 4002                  # 4002 = paper trading, 4001 = live
ibkr_client_id: 1
ibkr_reconnect_attempts: 3       # max reconnect attempts before failing
ibkr_daemon_max_connect_attempts: 10  # daemon reconnect attempts on IB Gateway drop

# ── S3 ───────────────────────────────────────────────────────────────────────
signals_bucket: "your-research-bucket-name"
trades_bucket: "your-executor-bucket-name"

# ── Email (sender must be verified in your AWS SES account) ──────────────────
email_sender: "you@example.com"
email_recipients:
  - "you@example.com"

# ── Strategy Layer ──────────────────────────────────────────────────────────
strategy:
  exit_manager:
    # ATR trailing stop: exit if price <= highest_high - ATR * multiplier
    atr_trailing_enabled: true
    atr_period: 14
    atr_multiplier: 2.5

    # Time-based decay: reduce after N days, exit after M days (if Research = HOLD)
    time_decay_enabled: true
    time_decay_reduce_days: 7
    time_decay_exit_days: 14

    # Profit-taking: emit REDUCE when unrealized gain exceeds threshold
    profit_take_enabled: true
    profit_take_pct: 0.25          # 25% gain triggers profit-take (backtester-tunable: [0.15, 0.20, 0.25, 0.30])

    # Sector-relative exit veto: suppress ATR exit if stock outperforms sector
    sector_relative_veto_enabled: true
    sector_relative_outperform_threshold: 0.05  # 5% outperformance suppresses exit (safety param)

    # Momentum-based exit: exit when momentum and RSI both signal weakness
    momentum_exit_enabled: true
    momentum_exit_threshold: -15.0  # 20d momentum % (backtester-tunable: [-20.0, -15.0, -10.0])
    momentum_exit_rsi: 30           # RSI(14) threshold

  graduated_drawdown:
    enabled: true
    tiers:
      - [-0.02, 1.00, "0% to -2%: full sizing"]
      - [-0.04, 0.50, "-2% to -4%: half sizing"]
      - [-0.06, 0.25, "-4% to -6%: quarter sizing"]

  # Drawdown forced exits — reduce portfolio risk during drawdowns (safety params)
  drawdown_forced_exit_enabled: true
  drawdown_forced_exit_tier2_count: 1   # force-exit N lowest-conviction positions at tier 2
  drawdown_forced_exit_tier3_count: 2   # force-exit N lowest-conviction positions at tier 3

  # Bracket stop: broker-side trailing stop on every ENTER order
  bracket:
    enabled: true
    trail_atr_multiple: 2.0             # trailing stop = ATR(14) * this value

# ── Intraday Daemon ─────────────────────────────────────────────────────────
# The daemon is the sole order executor. main.py writes the order book (entries,
# urgent exits, stops); the daemon reads it and executes all trades.
# Urgent exits execute immediately. Entries wait for technical triggers.
intraday:
  enabled: true                         # required: daemon is the sole executor
  client_id: 2                          # separate from morning batch (clientId=1)
  poll_interval_sec: 60                 # how often to check prices (data updates ~15 min)

  entry_triggers:
    enabled: true
    pullback_pct: 0.02                  # 2% pullback from intraday high
    vwap_discount_pct: 0.005            # 0.5% below previous day's VWAP
    support_pct: 0.01                   # within 1% of support level
    support_lookback_days: 20           # days to look back for support
    graduated_start_time: "14:00"       # start accepting "close enough" entries at 2 PM ET
    graduated_max_premium_pct: 0.01     # max 1% above morning price for graduated entry
    expiry_time: "15:55"                # unconditional market order at 3:55 PM ET

  exit_rules:
    trailing_stop_atr_multiple: 2.0     # intraday trailing stop (software-side)
    profit_take_pct: 0.08               # take 50% profit at 8% gain
    collapse_pct: 0.05                  # full exit on 5% intraday drop
    tighten_after_days: 3               # tighten trail to 1.5x ATR after 3 days
    tighten_atr_multiple: 1.5

# ── Notifications ───────────────────────────────────────────────────────────
# Telegram bot push notifications for intraday trades.
# Set TELEGRAM_BOT_TOKEN and TELEGRAM_CHAT_ID in .env (never in this file).
notifications:
  telegram:
    enabled: true
    notify_entries: true
    notify_exits: true
    notify_morning_batch: false

# ── Earnings proximity (O10) ──────────────────────────────────────────────
# Warn (log + email mention) when entering a position within N days of earnings.
# Informational only — not a gate. The predictor features handle the signal.
earnings_proximity_warning_days: 2

# ── Paths (adjust to your deployment) ───────────────────────────────────────
db_path: "/path/to/trades.db"
